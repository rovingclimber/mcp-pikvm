# Copy this to .env, fill in the values, then run docker compose up -d.
# .env is ignored by Git. Keep it private: it contains credentials.

# PiKVM connection. Leave these blank only if you want the server to expose
# its single setup-help tool and nothing else.
PIKVM_URL=https://192.168.1.50
PIKVM_USERNAME=admin
PIKVM_PASSWORD=replace-with-your-pikvm-password
PIKVM_TLS_VERIFY=true

# This persistent token lets a Codex client connect. It permits status and
# setup information only; it does not grant screen viewing or control.
MCP_HTTP_BEARER_TOKEN=replace-with-a-random-32-character-or-longer-token
MCP_HOST=0.0.0.0
MCP_PORT=8000
MCP_STREAMABLE_HTTP_PATH=/mcp

# LAN HTTP: set this to the Docker host's LAN IP or 0.0.0.0 deliberately.
# HTTPS overlay: leave it at 127.0.0.1; Traefik reaches the service privately.
MCP_BIND_ADDRESS=127.0.0.1
MCP_HTTP_ALLOWED_HOSTS=localhost:8000,127.0.0.1:8000,[::1]:8000
MCP_HTTP_ALLOWED_ORIGINS=

# Recommended HTTPS overlay (Cloudflare DNS-01):
# docker compose -f compose.yaml -f compose.https.yaml up -d
MCP_PUBLIC_HOST=mcp.example.com
ACME_EMAIL=you@example.com
CF_DNS_API_TOKEN=replace-with-a-zone-scoped-cloudflare-api-token

# Only needed when the PiKVM uses a private DNS name rather than an IP.
# PIKVM_ALLOW_PRIVATE_HOSTNAMES=1
# PIKVM_CA_BUNDLE=/path/in/container/to/pikvm-ca.pem
# PIKVM_ALLOW_INSECURE_HTTP=1
# PIKVM_ALLOW_INSECURE_TLS=1
# PIKVM_TLS_VERIFY=false
