# Streamable HTTP is the default transport. The Docker image listens on port
# 8000; bind that port to 127.0.0.1 unless a TLS reverse proxy is in front.
MCP_TRANSPORT=streamable-http
MCP_HOST=0.0.0.0
MCP_PORT=8000
MCP_STREAMABLE_HTTP_PATH=/mcp
# Set a random 32+ character value. Prefer MCP_HTTP_BEARER_TOKEN_FILE with
# Docker secrets, as shown in compose.yaml.
MCP_HTTP_BEARER_TOKEN=replace-with-a-separate-long-random-bearer-token
# These must match the Host header reaching the container. Do not use *.
MCP_HTTP_ALLOWED_HOSTS=localhost:8000,127.0.0.1:8000,[::1]:8000
# Native MCP clients usually omit Origin. Browser clients need exact origins.
MCP_HTTP_ALLOWED_ORIGINS=

# Use a literal private IP by default. Hostnames need an explicit opt-in.
PIKVM_URL=https://192.168.1.50
PIKVM_USERNAME=admin
PIKVM_PASSWORD=replace-with-a-dedicated-pikvm-account-password

# Keep certificate verification enabled. Point this to a PEM CA bundle if needed.
PIKVM_TLS_VERIFY=true
# PIKVM_CA_BUNDLE=C:\\path\\to\\pikvm-ca.pem

# Control tools stay unavailable until this secret is configured and supplied to
# pikvm_enable_control. Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
PIKVM_MCP_CONTROL_SECRET=replace-with-a-long-random-secret

# Optional, safe-by-default limits.
PIKVM_MCP_CONTROL_TTL_SECONDS=300
# Screens can contain secrets; this is intentionally off by default.
# PIKVM_MCP_SCREEN_CAPTURE_ENABLED=1
# PIKVM_MCP_SCREENSHOT_TTL_SECONDS=30
# Audit events are written to stderr by default, which is safe for a read-only
# container and available through its host logs. Set a writable mounted path
# only if you need a separate JSONL file.
# PIKVM_MCP_AUDIT_LOG=/var/log/pikvm-mcp/audit.jsonl

# Only needed when the PiKVM has a private DNS name. Every resolved address must
# be private or loopback; use a stable internal DNS server.
# PIKVM_ALLOW_PRIVATE_HOSTNAMES=1

# PiKVM_URL must use HTTPS unless this separate explicit opt-in is set.
# PIKVM_ALLOW_INSECURE_HTTP=1

# Never disable TLS verification unless you have independently verified the
# PiKVM certificate fingerprint over a trusted channel.
# PIKVM_ALLOW_INSECURE_TLS=1
# PIKVM_TLS_VERIFY=false
