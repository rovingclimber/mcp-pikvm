#!/bin/sh
# Launches one local-stdio MCP session inside the hardened Docker container.
set -eu

env_file="${PIKVM_MCP_ENV_FILE:-$HOME/.config/pikvm-local-mcp.env}"

if [ ! -f "$env_file" ]; then
    echo "Missing PiKVM MCP environment file: $env_file" >&2
    exit 78
fi

exec doas -n /usr/bin/docker run --rm -i \
    --read-only \
    --tmpfs /tmp:rw,noexec,nosuid,size=16m \
    --cap-drop=ALL \
    --security-opt=no-new-privileges \
    --env-file "$env_file" \
    --env MCP_TRANSPORT=stdio \
    pikvm-local-mcp:latest
