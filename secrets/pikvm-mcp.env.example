# Copy this file to secrets/pikvm-mcp.env (mode 0600) and update it.
# Secret values belong in the three separate secret files, not in this file.
MCP_TRANSPORT=streamable-http
MCP_HOST=0.0.0.0
MCP_PORT=8000
MCP_STREAMABLE_HTTP_PATH=/mcp
MCP_HTTP_ALLOWED_HOSTS=localhost:8000,127.0.0.1:8000,[::1]:8000
# Leave empty for native MCP clients. Add exact browser origins only if needed.
MCP_HTTP_ALLOWED_ORIGINS=

PIKVM_URL=https://192.168.1.50
PIKVM_USERNAME=codex-pikvm
PIKVM_TLS_VERIFY=true
PIKVM_MCP_CONTROL_TTL_SECONDS=300
PIKVM_MCP_SCREEN_CAPTURE_ENABLED=0
PIKVM_MCP_SCREENSHOT_TTL_SECONDS=30
